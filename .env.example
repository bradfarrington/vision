# Supabase — copy to .env.local and fill in from your project dashboard.
# Dashboard -> Project Settings -> API
#
# The URL and the "anon" / "publishable" key are safe to expose to the browser
# (that's why they're NEXT_PUBLIC_*). RLS is what protects your data — never put
# the service_role / secret key in a NEXT_PUBLIC_ var.

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# Base URL of this app, used for password-reset email redirect links.
# Local dev = http://localhost:3000; set to the deployed URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Maps (see AGENTS.md § Maps & geocoding)
# ---------------------------------------------------------------------------
# Both of these are OPTIONAL. With neither set, maps work: MapLibre renders free
# OpenStreetMap tiles and addresses are geocoded by Nominatim + postcodes.io.

# Vector tile style. Override to move off the free public tile host onto a paid
# or self-hosted one (MapTiler, Protomaps, your own tileserver).
# NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron

# Door-level geocoding. OpenStreetMap's UK house-number coverage is good but not
# complete, so some addresses resolve only to their street. Set this and every
# lookup goes to Google's Geocoding API instead, which returns ROOFTOP
# coordinates for UK premises. SERVER-ONLY — never give this a NEXT_PUBLIC_
# prefix; restrict the key to the Geocoding API in Google Cloud.
# Results are cached in `address_locations`, so it is one call per address, ever.
# GOOGLE_MAPS_API_KEY=

# Satellite + street view in the fullscreen map overlay (its Map / Satellite /
# Street view toggle). The map CARD is always MapLibre + OpenStreetMap and does
# not use this — see AGENTS.md § Maps & geocoding for why the split exists.
# This is Google's Maps EMBED API, which is FREE AND UNMETERED — unlike the
# Street View Static API, which bills per thumbnail, and the Maps JavaScript
# API, which bills per map load. Without it the overlay falls back to MapLibre
# and street view becomes a link out, so it degrades rather than breaks.
# PUBLIC by necessity (the browser requests the iframe), so in Google Cloud
# restrict it to the Maps Embed API and to this app's domains by HTTP referrer.
# Google requires a billing account on the project before issuing the key, even
# though this API is free.
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
